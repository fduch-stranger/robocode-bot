# Copy this file to .env and edit paths for your machine:
#
#   cp .env.example .env
#
# The scripts source .env automatically. Keep .env private; it is ignored by git.
# For temporary GUI/debug gun overrides, copy .env.guns.example to .env.guns.

# Python executable used by scripts/setup.sh when creating .venv.
PYTHON_BIN=python3

# Optional runtime Python override for bot launchers and telemetry tooling.
# Leave empty for normal repo usage: scripts prefer .venv/bin/python when it exists,
# and packaged bots fall back to python3 when .venv is not present.
ROBOCODE_PYTHON_BIN=

# Optional directory containing converted legacy Robocode bots.
# Leave empty to use ./legacy-bots, or set an absolute path for your machine.
ROBOCODE_LEGACY_BOTS_ROOT=

# Default telemetry viewer settings.
ROBOCODE_TELEMETRY_HOST=127.0.0.1
ROBOCODE_TELEMETRY_PORT=8765
ROBOCODE_TELEMETRY_PORT_FALLBACK=1

# Default telemetry directory for GUI-launched bots.
# CLI battles use battle-results/runs/<timestamp>/telemetry unless --telemetry-dir is passed.
ROBOCODE_TELEMETRY_DIR=battle-results/telemetry/live

# Open the telemetry viewer automatically when bots autostart it from the GUI.
# scripts/telemetry-ui.sh start opens the browser by default regardless of this value.
ROBOCODE_TELEMETRY_OPEN=0
