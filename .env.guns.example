# Copy this file to .env.guns for local GUI/debug gun overrides:
#
#   cp .env.guns.example .env.guns
#
# The scripts and GUI bot launchers load .env first, then .env.guns. Keep
# .env.guns private; it is ignored by git. Already-exported shell variables
# still take precedence over both files. In packaged GUI installs, place this
# file beside the extracted bot directories.
#
# Current defaults when no overrides are enabled:
# - No pinned gun for any bot.
# - Live selectable gun set for every bot:
#   linear, traditional_gf, dynamic_cluster
# - Force-testable/pinnable gun set for every bot:
#   head_on, linear, linear_wall_aware, displacement, traditional_gf,
#   dynamic_cluster, anti_surfer
#
# To clear a matching gun setting from .env, uncomment the variable with an
# empty value. Otherwise leave unused overrides commented out.

# Global overrides for all bots.
# ROBOCODE_GUN_MODE=
# ROBOCODE_GUN_SET=

# Per-bot pins. These override ROBOCODE_GUN_MODE.
# ROBOCODE_ADAPTIVE_GUN_MODE=
# ROBOCODE_CHASE_GUN_MODE=
# ROBOCODE_CIRCLE_GUN_MODE=
# ROBOCODE_SWEEP_GUN_MODE=

# Per-bot live selectable sets. These override ROBOCODE_GUN_SET.
# ROBOCODE_ADAPTIVE_GUN_SET=
# ROBOCODE_CHASE_GUN_SET=
# ROBOCODE_CIRCLE_GUN_SET=
# ROBOCODE_SWEEP_GUN_SET=

# Useful GUI examples. Uncomment one at a time:
#
# Pin Adaptive Prime to Traditional GF:
# ROBOCODE_ADAPTIVE_GUN_MODE=traditional_gf
#
# Let Adaptive Prime live-select only these two guns:
# ROBOCODE_ADAPTIVE_GUN_SET=dynamic_cluster,traditional_gf
#
# Pin every bot to linear where supported:
# ROBOCODE_GUN_MODE=linear
